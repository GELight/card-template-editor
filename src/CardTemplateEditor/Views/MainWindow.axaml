<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CardTemplateEditor.ViewModels"
        xmlns:controls="using:CardTemplateEditor.Views.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        Width="1200" Height="700"
        MinWidth="800" MinHeight="500"
        x:Class="CardTemplateEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Card Template Editor">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Window-lokale Styles für die kompakten Properties-Panel-Sektionen.
         section-tag = kleines Label am Anfang einer Gruppe.
         row-label   = inline-Label links neben einem Eingabefeld.
         align-icon  = quadratischer Toggle-Button für Ausrichtungs-Icons,
                       mit Akzent-Hintergrund im IsChecked-State.
         align-glyph = das Path-Icon innerhalb eines align-icon-Buttons. -->
    <Window.Styles>
        <Style Selector="TextBlock.section-tag">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundMutedBrush}" />
            <Setter Property="Margin" Value="0,4,0,2" />
        </Style>
        <Style Selector="TextBlock.row-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Opacity" Value="0.85" />
        </Style>
        <Style Selector="ToggleButton.align-icon">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="2,0" />
        </Style>
        <Style Selector="ToggleButton.align-icon:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="Path.align-glyph">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Stretch" Value="None" />
            <Setter Property="Stroke" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="StrokeThickness" Value="1.6" />
            <Setter Property="StrokeLineCap" Value="Round" />
        </Style>
        <Style Selector="ToggleButton.align-icon:checked Path.align-glyph">
            <Setter Property="Stroke" Value="#FF1F1612" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top: Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="_Datei">
                <MenuItem Header="_Neues Template" Command="{Binding NewTemplateCommand}" />
                <Separator />
                <MenuItem Header="_Datenverzeichnis…"
                          Click="OnChooseDataDirectoryClick"
                          ToolTip.Tip="{Binding CurrentDataDirectory, StringFormat='Aktuell: {0}'}" />
                <Separator />
                <MenuItem Header="_Beenden" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Template">
                <MenuItem Header="_Bild hinzufügen…" Click="OnAddImageClick"
                          IsEnabled="{Binding CurrentTemplate, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <MenuItem Header="Text_feld hinzufügen" Command="{Binding AddTextFieldCommand}" />
            </MenuItem>
            <MenuItem Header="_Export">
                <MenuItem Header="_Aktuelles Set exportieren…" Click="OnExportCurrentSetClick"
                          IsEnabled="{Binding CurrentTemplate, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <MenuItem Header="_Batch-Export aller Sets…" Click="OnBatchExportClick"
                          IsEnabled="{Binding CurrentTemplate, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </MenuItem>
        </Menu>

        <!-- Center: 3 columns with splitters. -->
        <Grid Grid.Row="1" ColumnDefinitions="220,4,*,4,260">

            <!-- Left: Templates + Bilder + Textsets, alles inline editierbar.
                 Kein separates "Umbenennen-Dialog"-Panel mehr — Klick in den Namen
                 reicht, ✕-Button neben jeder Zeile löscht den Eintrag. -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0" Padding="8">

                <Border.Styles>
                    <!-- Diskreter Lösch-Button: nur als ✕, keine sichtbare Border. -->
                    <Style Selector="Button.row-action">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="6,2" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="MinWidth" Value="0" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="Opacity" Value="0.55" />
                    </Style>
                    <Style Selector="Button.row-action:pointerover">
                        <Setter Property="Opacity" Value="1" />
                    </Style>
                </Border.Styles>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="0">
                    <!-- Section: Templates -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Templates" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="+ Neu"
                                Command="{Binding NewTemplateCommand}"
                                Padding="8,2" />
                    </Grid>
                    <ListBox MaxHeight="180" Margin="0,0,0,12"
                             ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding CurrentTemplate, Mode=TwoWay}">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="6,2" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:TemplateViewModel">
                                <Grid ColumnDefinitions="*,Auto">
                                    <controls:InlineEditableLabel Grid.Column="0"
                                                                   Text="{Binding Name, Mode=TwoWay}"
                                                                   ToolTip.Tip="Doppelklick zum Umbenennen" />
                                    <Button Grid.Column="1" Classes="row-action"
                                            Content="✕"
                                            ToolTip.Tip="Template löschen"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveTemplateCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Section: Bilder -->
                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Bilder" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="+ Bild"
                                Click="OnAddImageClick"
                                IsEnabled="{Binding CurrentTemplate, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Padding="8,2" Margin="0,0,4,0" />
                        <Button Grid.Column="2" Content="+ Textfeld"
                                Command="{Binding AddTextFieldCommand}"
                                Padding="8,2" />
                    </Grid>
                    <ListBox MaxHeight="140" Margin="0,0,0,12"
                             ItemsSource="{Binding CurrentTemplate.ImageSlots}"
                             SelectedItem="{Binding SelectedImageSlot, Mode=TwoWay}">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="6,2" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:ImageSlotViewModel">
                                <Grid ColumnDefinitions="*,Auto">
                                    <controls:InlineEditableLabel Grid.Column="0"
                                                                   Text="{Binding Name, Mode=TwoWay}"
                                                                   ToolTip.Tip="Doppelklick zum Umbenennen" />
                                    <Button Grid.Column="1" Classes="row-action"
                                            Content="✕"
                                            ToolTip.Tip="Bild entfernen"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveImageSlotCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Section: Textsets -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Textsets" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="+ Neu"
                                Command="{Binding AddTextsetCommand}"
                                Padding="8,2" />
                    </Grid>
                    <ListBox MaxHeight="200" Margin="0,0,0,8"
                             ItemsSource="{Binding CurrentTemplate.Textsets}"
                             SelectedItem="{Binding SelectedTextset, Mode=TwoWay}">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="6,2" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:TextsetViewModel">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <controls:InlineEditableLabel Grid.Column="0"
                                                                   Text="{Binding Name, Mode=TwoWay}"
                                                                   ToolTip.Tip="Doppelklick zum Umbenennen" />
                                    <Button Grid.Column="1" Classes="row-action"
                                            Content="✓"
                                            ToolTip.Tip="Set anwenden"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ApplyTextsetCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="2" Classes="row-action"
                                            Content="✕"
                                            ToolTip.Tip="Set löschen"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveTextsetCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />

            <!-- Center: Canvas with images. UniformGrid Rows=1 teilt die verfügbare
                 Breite gleichmäßig auf alle ImageSlots auf; jeder EditableImageCanvas
                 skaliert sich per Viewbox (Stretch=Uniform) automatisch in seine Zelle.

                 Über dem Canvas-Bereich sitzt die Mode-Switcher-Toolbar:
                 4 RadioButtons mit Farb-Indikator pro Mode (Skalieren=Blau,
                 Perspektive=Gold, Schräg=Grün, Drehen=Orange). Aktiver Mode
                 bestimmt, was Linksklick auf einen der 8 Handles auslöst. -->
            <Border Grid.Column="2" Padding="8">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="4,2"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,0,0,1">
                        <!-- Reine Status-Anzeige: zeigt den aktuell aktiven
                             Modus, abgeleitet aus den live gehaltenen
                             Modifier-Tasten (Strg / Alt / Shift+Alt). Kein
                             Toggle mehr — der User wechselt den Modus rein
                             über die Tastatur. -->
                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Modus:" VerticalAlignment="Center"
                                       FontSize="11" Opacity="0.7" />
                            <Rectangle Width="10" Height="10"
                                       VerticalAlignment="Center"
                                       Fill="{Binding EditModeIndicatorBrush}" />
                            <TextBlock Text="{Binding EditModeDisplayName}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="12" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11" Opacity="0.5"
                                       Margin="12,0,0,0"
                                       Text="(Strg = Perspektive · Alt = Aspekt-Lock · Shift+Alt = Schräg)" />
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding CurrentTemplate.ImageSlots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ImageSlotViewModel">
                                    <controls:EditableImageCanvas Margin="4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding PlaceholderText}"
                                   IsVisible="{Binding CurrentTemplate, Converter={x:Static ObjectConverters.IsNull}}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="20"
                                   Opacity="0.6" />
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />

            <!-- Right: Properties — kontextabhängig.
                 Zeigt unabhängig voneinander Textfeld-Properties (wenn ein Feld
                 selektiert ist) und Textset-Werte (wenn ein Set selektiert ist).
                 Beides kann gleichzeitig sichtbar sein. -->
            <Border Grid.Column="4" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1,0,0,0" Padding="6">
                <Grid>
                    <!-- Hinweis, wenn nichts selektiert ist -->
                    <StackPanel Spacing="6">
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="SelectedTextField" Converter="{x:Static ObjectConverters.IsNull}" />
                                <Binding Path="SelectedTextset" Converter="{x:Static ObjectConverters.IsNull}" />
                            </MultiBinding>
                        </StackPanel.IsVisible>
                        <TextBlock Text="Eigenschaften" FontWeight="SemiBold" />
                        <TextBlock Text="(Wähle ein Textfeld oder ein Textset)" Opacity="0.6" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- ScrollBarVisibility=Auto: Scrollbar erscheint nur wenn
                         tatsächlich nötig, sonst nutzen die Felder die volle
                         Breite. Das rechte Padding (8) bleibt als Sicherheits-
                         abstand, damit Eingabefelder nicht direkt am Border
                         kleben. -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,8,0">
                        <StackPanel Spacing="14">

                            <!-- Sektion: Textset-Werte (zuerst, weil häufiger benötigt) -->
                            <StackPanel Spacing="6"
                                        IsVisible="{Binding SelectedTextset, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Text="{Binding SelectedTextset.Name, StringFormat='Textset: {0}'}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1" Content="Anwenden"
                                            Padding="8,2"
                                            Command="{Binding ApplyTextsetCommand}"
                                            CommandParameter="{Binding SelectedTextset}" />
                                </Grid>
                                <TextBlock Text="Werte je Bild" FontSize="12" Opacity="0.7" />

                                <!-- Eingaben gruppiert nach Bild: pro ImageSlot eine
                                     Sektion mit Header und nested ItemsControl über
                                     die Feldnamen dieses Slots. Felder mit gleichem
                                     Namen in mehreren Slots erscheinen in jeder
                                     Sektion, lesen aber denselben Wert aus dem
                                     Textset-Modell. -->
                                <ItemsControl ItemsSource="{Binding SelectedTextsetGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:TextsetGroupViewModel">
                                            <StackPanel Spacing="4" Margin="0,0,0,10">
                                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                        Padding="6,3"
                                                        CornerRadius="3">
                                                    <TextBlock Text="{Binding SlotName}"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <ItemsControl ItemsSource="{Binding Entries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="vm:TextsetEntryViewModel">
                                                            <Grid ColumnDefinitions="*" RowDefinitions="Auto,Auto" Margin="0,0,0,6">
                                                                <TextBlock Grid.Row="0"
                                                                           Text="{Binding FieldName}"
                                                                           FontSize="12" Opacity="0.7"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBox Grid.Row="1"
                                                                         Text="{Binding Value, Mode=TwoWay}" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Sektion: Textfeld-Properties.

                                 Layout-Konzept (kompakt):
                                 - Inline-Label-Layout: kleines Label links, Wert
                                   rechts. Spart vertikalen Platz gegenüber der
                                   alten "Label-über-Spinner"-Anordnung.
                                 - Logische Gruppen mit kleinen Header-Tags:
                                   IDENTITÄT (Name + Text) → SCHRIFT (Family /
                                   Größe / Schnitt) → FORM (Stretch / Auto-Fit
                                   / LineHeight / LetterSpacing) → AUSRICHTUNG
                                   (H+V als Icon-Toggles + Drehung) → FARBE.
                                 - Die alte Perspektive-Expander ist entfernt;
                                   Eckpunkte werden ausschließlich per Maus
                                   im Editor verschoben (User-Wunsch). -->
                            <ContentControl Content="{Binding SelectedTextField}"
                                            IsVisible="{Binding SelectedTextField, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate DataType="vm:TextFieldViewModel">
                                        <StackPanel Spacing="10">

                                            <!-- HEADER -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="Textfeld" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <Button Grid.Column="1"
                                                        Content="✕ Löschen"
                                                        Padding="8,2"
                                                        Click="OnDeleteSelectedTextFieldClick" />
                                            </Grid>

                                            <!-- IDENTITÄT -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="IDENTITÄT" Classes="section-tag" />
                                                <Grid ColumnDefinitions="52,*" RowDefinitions="Auto,Auto" RowSpacing="4">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Classes="row-label" />
                                                    <TextBox    Grid.Row="0" Grid.Column="1" Name="NameBox"
                                                                Text="{Binding Name, Mode=TwoWay}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Text" Classes="row-label" />
                                                    <TextBox    Grid.Row="1" Grid.Column="1" Name="CurrentTextBox"
                                                                Text="{Binding CurrentText, Mode=TwoWay}"
                                                                AcceptsReturn="True" MinHeight="50" />
                                                </Grid>
                                            </StackPanel>

                                            <!-- SCHRIFT -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="SCHRIFT" Classes="section-tag" />
                                                <Grid ColumnDefinitions="52,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                                                    <!-- Schriftart-Dropdown rendert jeden Eintrag in seiner
                                                         eigenen Family — User sieht beim Aufklappen die
                                                         echte Schrift. FontFamily-Binding pro Item nutzt
                                                         den string-Wert direkt; FontFamily akzeptiert
                                                         implizite string→FontFamily-Konvertierung. -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Family" Classes="row-label" />
                                                    <ComboBox  Grid.Row="0" Grid.Column="1" Name="FontFamilyBox"
                                                               ItemsSource="{x:Static vm:FontResources.AvailableFontFamilies}"
                                                               SelectedItem="{Binding FontFamily, Mode=TwoWay}"
                                                               HorizontalAlignment="Stretch">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate DataType="x:String">
                                                                <TextBlock Text="{Binding}"
                                                                           FontFamily="{Binding}"
                                                                           FontSize="14" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Größe" Classes="row-label" />
                                                    <NumericUpDown Grid.Row="1" Grid.Column="1" Name="FontSizeBox"
                                                                   Value="{Binding FontSize, Mode=TwoWay}"
                                                                   Minimum="6" Maximum="2000" Increment="1" />

                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Schnitt" Classes="row-label" />
                                                    <ComboBox  Grid.Row="2" Grid.Column="1" Name="FontWeightBox"
                                                               ItemsSource="{x:Static vm:FontResources.AvailableFontWeights}"
                                                               SelectedItem="{Binding FontWeight, Mode=TwoWay}"
                                                               HorizontalAlignment="Stretch" />
                                                </Grid>
                                            </StackPanel>

                                            <!-- FORM (Stretch + Linehöhe + Letter-Spacing) -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="FORM" Classes="section-tag" />
                                                <Grid ColumnDefinitions="52,*,4,*"
                                                      RowDefinitions="Auto,Auto,Auto"
                                                      RowSpacing="4">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Stretch" Classes="row-label" />
                                                    <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                                   Value="{Binding StretchX, Mode=TwoWay}"
                                                                   Minimum="0.1" Maximum="20" Increment="0.1"
                                                                   FormatString="0.##"
                                                                   IsEnabled="{Binding !AutoFit}" />
                                                    <NumericUpDown Grid.Row="0" Grid.Column="3"
                                                                   Value="{Binding StretchY, Mode=TwoWay}"
                                                                   Minimum="0.1" Maximum="20" Increment="0.1"
                                                                   FormatString="0.##"
                                                                   IsEnabled="{Binding !AutoFit}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Zeilen" Classes="row-label" />
                                                    <NumericUpDown Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                                                   Value="{Binding LineHeight, Mode=TwoWay}"
                                                                   Minimum="0" Maximum="2000" Increment="1"
                                                                   FormatString="0.#" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Spacing" Classes="row-label" />
                                                    <NumericUpDown Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                                                   Value="{Binding LetterSpacing, Mode=TwoWay}"
                                                                   Minimum="-50" Maximum="200" Increment="0.5"
                                                                   FormatString="0.##" />
                                                </Grid>
                                                <CheckBox IsChecked="{Binding AutoFit, Mode=TwoWay}"
                                                          Content="Auto-Fit (Text füllt die Box)"
                                                          Padding="6,0,0,0" />
                                            </StackPanel>

                                            <!-- AUSRICHTUNG: H+V als 6 Icon-Toggle-Buttons.
                                                 Jeder Button setzt seine Property direkt auf den
                                                 entsprechenden Wert; IsChecked-Trigger zeigt den
                                                 aktiven Zustand mit Akzent-Hintergrund.

                                                 Verwendet werden Avalonia.Path-Geometrien (Material-
                                                 Design-style "Format-Align"-Icons), keine externen
                                                 Resources. So bleibt das Theme self-contained. -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="AUSRICHTUNG" Classes="section-tag" />
                                                <Grid ColumnDefinitions="52,*">
                                                    <TextBlock Grid.Column="0" Text="Horiz." Classes="row-label" />
                                                    <UniformGrid Grid.Column="1" Columns="3" Rows="1">
                                                        <ToggleButton Classes="align-icon"
                                                                      IsChecked="{Binding IsAlignLeft, Mode=TwoWay}"
                                                                      ToolTip.Tip="Links">
                                                            <Path Classes="align-glyph"
                                                                  Data="M 2,3 H 14 M 2,7 H 10 M 2,11 H 14 M 2,15 H 8" />
                                                        </ToggleButton>
                                                        <ToggleButton Classes="align-icon"
                                                                      IsChecked="{Binding IsAlignCenter, Mode=TwoWay}"
                                                                      ToolTip.Tip="Zentriert">
                                                            <Path Classes="align-glyph"
                                                                  Data="M 2,3 H 14 M 4,7 H 12 M 2,11 H 14 M 5,15 H 11" />
                                                        </ToggleButton>
                                                        <ToggleButton Classes="align-icon"
                                                                      IsChecked="{Binding IsAlignRight, Mode=TwoWay}"
                                                                      ToolTip.Tip="Rechts">
                                                            <Path Classes="align-glyph"
                                                                  Data="M 2,3 H 14 M 6,7 H 14 M 2,11 H 14 M 8,15 H 14" />
                                                        </ToggleButton>
                                                    </UniformGrid>
                                                </Grid>
                                                <Grid ColumnDefinitions="52,*">
                                                    <TextBlock Grid.Column="0" Text="Vert." Classes="row-label" />
                                                    <UniformGrid Grid.Column="1" Columns="3" Rows="1">
                                                        <ToggleButton Classes="align-icon"
                                                                      IsChecked="{Binding IsAlignTop, Mode=TwoWay}"
                                                                      ToolTip.Tip="Oben">
                                                            <Path Classes="align-glyph"
                                                                  Data="M 2,2 H 14 M 4,5 H 12 M 4,8 H 12 M 4,11 H 12 M 4,14 H 12" />
                                                        </ToggleButton>
                                                        <ToggleButton Classes="align-icon"
                                                                      IsChecked="{Binding IsAlignMiddle, Mode=TwoWay}"
                                                                      ToolTip.Tip="Mittig">
                                                            <Path Classes="align-glyph"
                                                                  Data="M 4,4 H 12 M 4,7 H 12 M 2,9 H 14 M 4,11 H 12 M 4,14 H 12" />
                                                        </ToggleButton>
                                                        <ToggleButton Classes="align-icon"
                                                                      IsChecked="{Binding IsAlignBottom, Mode=TwoWay}"
                                                                      ToolTip.Tip="Unten">
                                                            <Path Classes="align-glyph"
                                                                  Data="M 4,2 H 12 M 4,5 H 12 M 4,8 H 12 M 4,11 H 12 M 2,14 H 14" />
                                                        </ToggleButton>
                                                    </UniformGrid>
                                                </Grid>
                                                <Grid ColumnDefinitions="52,*">
                                                    <TextBlock Grid.Column="0" Text="Drehung" Classes="row-label" />
                                                    <NumericUpDown Grid.Column="1" Name="RotationBox"
                                                                   Value="{Binding Rotation, Mode=TwoWay}"
                                                                   Minimum="-180" Maximum="180" Increment="1"
                                                                   FormatString="0.#" />
                                                </Grid>
                                            </StackPanel>

                                            <!-- FARBE -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="FARBE" Classes="section-tag" />
                                                <ColorPicker Name="ColorBox"
                                                             Color="{Binding ColorValue, Mode=TwoWay}"
                                                             HorizontalAlignment="Stretch" />
                                            </StackPanel>

                                            <!-- NOTAUSGÄNGE: Reset für Eckpunkte und Drehpunkt.
                                                 Falls der User einen Punkt versehentlich aus dem
                                                 sichtbaren Bereich gezogen hat, sind diese Buttons
                                                 der einfache Weg zurück zum Default. -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="ZURÜCKSETZEN" Classes="section-tag" />
                                                <Button Content="Eckpunkte zurücksetzen"
                                                        Click="OnResetCornerOffsetsClick"
                                                        ToolTip.Tip="Setzt alle 4 Eckpunkt-Verzerrungen auf 0 zurück" />
                                                <Button Content="Drehpunkt zurücksetzen"
                                                        Click="OnResetRotationOriginClick"
                                                        ToolTip.Tip="Setzt den Drehpunkt zurück auf die Frame-Mitte" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom: Action bar.
             Layout-Strategie: links das Datei-Pattern, rechts die Action-Buttons,
             dazwischen ein elastisches Status-Feld (LastChildFill). Der Status-Text
             nutzt TextTrimming, damit lange Pfade die Buttons nicht aus dem Sichtfeld
             schieben. -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,1,0,0" Padding="8">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Text="Datei-Pattern:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox DockPanel.Dock="Left" Width="260" Text="{Binding FileNamePattern, Mode=TwoWay}" />
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="8,0,0,0"
                           Opacity="0.7" FontSize="12"
                           Text="{Binding FileNamePatternPreview}" />

                <ProgressBar DockPanel.Dock="Right"
                             Width="120" Height="14" Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             Minimum="0" Maximum="1"
                             Value="{Binding BatchProgressFraction}"
                             IsVisible="{Binding IsBatchRunning}" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           Text="{Binding BatchProgressLabel}"
                           IsVisible="{Binding IsBatchRunning}" />
                <Button DockPanel.Dock="Right" Content="Batch-Export"
                        Margin="8,0,0,0"
                        Click="OnBatchExportClick"
                        IsEnabled="{Binding CurrentTemplate, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <Button DockPanel.Dock="Right" Content="Aktuelles Set exportieren…"
                        Margin="8,0,0,0"
                        Click="OnExportCurrentSetClick"
                        IsEnabled="{Binding CurrentTemplate, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <Button DockPanel.Dock="Right" Content="Update"
                        Margin="8,0,0,0"
                        Command="{Binding UpdateExportCommand}"
                        ToolTip.Tip="{Binding LastExportDirectory, StringFormat='Letzten Export überschreiben: {0}', FallbackValue='Erst einmal regulär exportieren, dann ist Update aktiv.'}" />

                <!-- Last child: füllt den mittleren Rest. TextTrimming sorgt dafür,
                     dass lange Pfade abgeschnitten werden, statt die Buttons zu verdrängen.
                     Vollständiger Pfad steht im ToolTip. -->
                <TextBlock VerticalAlignment="Center"
                           Margin="16,0"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding ExportStatus}"
                           Text="{Binding ExportStatus}"
                           IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
