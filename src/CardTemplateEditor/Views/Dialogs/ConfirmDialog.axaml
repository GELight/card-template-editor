<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CardTemplateEditor.Views.Dialogs.ConfirmDialog"
        Width="420" SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="*,Auto" Margin="16">
        <TextBlock Grid.Row="0"
                   Name="MessageBlock"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Name="CancelButton" Content="Abbrechen" MinWidth="90" Click="OnCancel" />
            <Button Name="ConfirmButton" Content="Löschen" MinWidth="90" Click="OnConfirm"
                    Classes="accent" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
